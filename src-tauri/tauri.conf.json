{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shikigami",
  "version": "0.1.0-alpha.0",
  "identifier": "dev.shikigami.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shikigami",
        "width": 480,
        "height": 640,
        "minWidth": 280,
        "minHeight": 360,
        "maxWidth": 1200,
        "maxHeight": 1600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visibleOnAllWorkspaces": true,
        "shadow": false,
        "center": false,
        "focus": true,
        "visible": true,
        "x": 100,
        "y": 100
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.shikigami/characters/**",
          "$HOME/.shikigami/tts/**",
          "$RESOURCE/characters/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../characters/hiyori/**/*",
      "../characters/haru/**/*",
      "../characters/mao/**/*",
      "../characters/fili/**/*",
      "../characters/linh-pixel/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "signingIdentity": null,
      "providerShortName": null,
      "hardenedRuntime": true
    },
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator-gtk3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Desktop companion for AI coding sessions",
    "longDescription": "Shikigami is a summoned desktop companion that reflects your AI agent's real-time state via a 2D animated character."
  }
}
