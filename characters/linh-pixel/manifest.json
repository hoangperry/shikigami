{
  "$schema": "https://shikigami.dev/schema/manifest/v1.0.json",
  "schemaVersion": "1.0",
  "id": "linh-pixel",
  "name": "Linh (Pixel Dev Fixture)",
  "description": "8-bit pixel-art placeholder of the default Linh character. Used as a development fixture while the production character assets are being produced. Generated procedurally from ASCII-art grids by src/generate.py.",
  "author": "hoangperry",
  "version": "0.1.0",
  "license": "MIT",
  "tags": ["pixel", "8-bit", "dev-fixture", "placeholder", "sfw"],
  "renderer": "sprite",
  "defaultState": "idle",
  "states": {
    "idle": {
      "path": "assets/states/idle",
      "fps": 4,
      "loop": true
    },
    "happy": {
      "path": "assets/states/happy",
      "fps": 6,
      "loop": false,
      "then": "idle",
      "durationMs": 800
    },
    "happy_relieved": {
      "path": "assets/states/happy_relieved",
      "fps": 4,
      "loop": false,
      "then": "idle",
      "durationMs": 1500
    },
    "focused": {
      "path": "assets/states/focused",
      "fps": 4,
      "loop": true
    },
    "warning": {
      "path": "assets/states/warning",
      "fps": 6,
      "loop": true
    },
    "sleepy": {
      "path": "assets/states/sleepy",
      "fps": 3,
      "loop": true
    }
  }
}
