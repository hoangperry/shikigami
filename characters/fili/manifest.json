{
  "$schema": "https://shikigami.dev/schema/manifest/v1.0.json",
  "schemaVersion": "1.0",
  "id": "fili",
  "name": "FILI (CC0 Filipino VTuber)",
  "description": "CC0 community VTuber model. Free for any use.",
  "author": "MjGjVtube",
  "version": "1.0.0",
  "license": "CC0-1.0",
  "tags": ["live2d", "vtuber", "community", "cc0", "sfw"],
  "renderer": "live2d",
  "defaultState": "idle",
  "states": {
    "idle":    { "path": "assets/states/idle",    "fps": 30, "loop": true,  "motion": null },
    "happy":   { "path": "assets/states/happy",   "fps": 30, "loop": false, "then": "idle", "durationMs": 2000, "motion": null },
    "focused": { "path": "assets/states/focused", "fps": 30, "loop": true,  "motion": null },
    "warning": { "path": "assets/states/warning", "fps": 30, "loop": true,  "motion": null },
    "sleepy":  { "path": "assets/states/sleepy",  "fps": 30, "loop": true,  "motion": null }
  }
}
