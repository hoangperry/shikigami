{
  "name": "shikigami",
  "private": true,
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "A summoned desktop companion that reflects your AI agent's real-time state.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\" \"*.{ts,json,md}\""
  },
  "dependencies": {
    "@pixi/sound": "^5.2.3",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "pixi-live2d-display-mulmotion": "0.5.0-mm-6",
    "pixi.js": "^7.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
